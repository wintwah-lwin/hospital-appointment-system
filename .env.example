# Server (Node — never prefix these with VITE_)
# If you change PORT, set VITE_API_BASE_URL to the same host:port (see below).
PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/intellicare
JWT_SECRET=change_this_to_a_long_random_secret

ADMIN_EMAIL=admin@intellicare.local
ADMIN_PASSWORD=your_secure_admin_password
STAFF_SEED=

# SKIP_GEO_CHECK=true

# Frontend (Vite — only VITE_* is available in the browser)
# Must match PORT above (e.g. http://localhost:5001 if PORT=5001).
VITE_API_BASE_URL=http://localhost:5001
