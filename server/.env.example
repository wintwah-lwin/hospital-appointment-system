PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/intellicare
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret

# System-managed accounts (auto-created if missing)
ADMIN_EMAIL=admin@intellicare.local
# DO NOT use defaults in production. Set a strong password.
ADMIN_PASSWORD=your_secure_admin_password

# Optional: seed staff accounts (comma-separated)
# Example: doctor1@intellicare.local:Doctor123!,nurse1@intellicare.local:Nurse123!
STAFF_SEED=

# Geo restriction: set to "true" to skip Singapore/VPN checks (e.g. local dev with localhost)
# SKIP_GEO_CHECK=true

